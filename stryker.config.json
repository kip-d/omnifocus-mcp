{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing for src/contracts/ast/ — the CI-blind tag/mutation/script AST builders. Measures whether the unit suite actually catches injected bugs (mutation score), not just line coverage. Run: npx stryker run. Scope a subset with: npx stryker run --mutate 'src/contracts/ast/tag-script-builder.ts'.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "coverageAnalysis": "perTest",
  "mutate": ["src/contracts/ast/**/*.ts", "!src/contracts/ast/**/*.d.ts", "!src/contracts/ast/insights/**"],
  "reporters": ["html", "json", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/ast/index.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/ast/report.json"
  },
  "clearTextReporter": {
    "allowColor": true,
    "maxTestsToLog": 3
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "concurrency": 4,
  "timeoutMS": 60000,
  "disableTypeChecks": true
}
